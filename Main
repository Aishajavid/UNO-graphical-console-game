/*=============================================================
  UNO Card Game Simulator  —  main.cpp
  SFML + C++   |   DSA Semester 3 Project
=============================================================*/

#include <SFML/Graphics.hpp>
#include <SFML/Audio.hpp>
#include <iostream>
#include <sstream>
#include <vector>
#include <string>
#include <algorithm>

#include "GameState.h"
#include "CardRenderer.h"
#include "UIHelper.h"

// ── Window constants ──────────────────────────────────────────────────────
const unsigned WIN_W = 1100;
const unsigned WIN_H = 700;

// ── Setup state (used before game starts) ────────────────────────────────
struct SetupData {
    int  totalPlayers = 2;   // 2-6
    int  humanCount = 1;   // how many are human
    std::vector<std::string> names;
    std::string inputBuffer;  // for text entry
    int  editingIdx = -1;  // which name we're typing

    void reset() {
        totalPlayers = 2;
        humanCount = 1;
        names.clear();
        inputBuffer.clear();
        editingIdx = -1;
    }
};

// ── Screen enum ───────────────────────────────────────────────────────────
enum class Screen { MAIN_MENU, SETUP, GAME, GAME_OVER };

// ── Forward declarations ──────────────────────────────────────────────────
void drawMainMenu(sf::RenderWindow& w, const sf::Font& font, int hover);
void drawSetupScreen(sf::RenderWindow& w, const sf::Font& font,
    SetupData& setup);
void drawGame(sf::RenderWindow& w, const sf::Font& font, GameState& gs,
    int hoverCard, bool showColorPicker);
void drawColorPicker(sf::RenderWindow& w, const sf::Font& font);
void drawGameOver(sf::RenderWindow& w, const sf::Font& font, GameState& gs);

// ── Helper: draw background ───────────────────────────────────────────────
void drawBG(sf::RenderWindow& w) {
    // Deep green felt-style background
    w.clear(sf::Color(18, 80, 40));

    // Subtle grid / felt texture lines
    for (int i = 0; i < (int)WIN_W; i += 40) {
        sf::RectangleShape line(sf::Vector2f(1, WIN_H));
        line.setPosition((float)i, 0);
        line.setFillColor(sf::Color(0, 0, 0, 18));
        w.draw(line);
    }
    for (int i = 0; i < (int)WIN_H; i += 40) {
        sf::RectangleShape line(sf::Vector2f(WIN_W, 1));
        line.setPosition(0, (float)i);
        line.setFillColor(sf::Color(0, 0, 0, 18));
        w.draw(line);
    }
}

// ── Main ──────────────────────────────────────────────────────────────────
int main() {
    sf::RenderWindow window(sf::VideoMode(WIN_W, WIN_H),
        "UNO Simulator",
        sf::Style::Close | sf::Style::Titlebar);
    window.setFramerateLimit(60);

    // Load font
    sf::Font font;
    // Try a few common system font paths
    bool fontLoaded = font.loadFromFile("arial.ttf");
    if (!fontLoaded) fontLoaded = font.loadFromFile("C:/Windows/Fonts/arial.ttf");
    if (!fontLoaded) fontLoaded = font.loadFromFile("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf");
    if (!fontLoaded) fontLoaded = font.loadFromFile("/System/Library/Fonts/Helvetica.ttc");
    if (!fontLoaded) {
        std::cerr << "[WARNING] Could not load font. Text may not render.\n";
    }

    Screen     screen = Screen::MAIN_MENU;
    SetupData  setup;
    GameState  gs;

    int  hoverCard = -1;
    bool showColorPicker = false;
    int  menuHover = -1;

    // Bot turn timer (so bot moves feel slightly delayed, not instant)
    sf::Clock botClock;
    const float BOT_DELAY = 0.9f; // seconds

    // ── Event loop ────────────────────────────────────────────────────────
    while (window.isOpen()) {
        sf::Event event;
        sf::Vector2i mouse = sf::Mouse::getPosition(window);

        // ── Process events ────────────────────────────────────────────────
        while (window.pollEvent(event)) {
            if (event.type == sf::Event::Closed)
                window.close();

            // ── MAIN MENU ─────────────────────────────────────────────────
            if (screen == Screen::MAIN_MENU) {
                if (event.type == sf::Event::MouseButtonPressed &&
                    event.mouseButton.button == sf::Mouse::Left)
                {
                    // Button rects (must match drawMainMenu layout)
                    float bx = WIN_W / 2.f - 120, by0 = 300, bw = 240, bh = 50, gap = 70;
                    if (UI::contains({ bx, by0,        bw, bh }, mouse)) {
                        setup.reset(); screen = Screen::SETUP;
                    }
                    else if (UI::contains({ bx, by0 + gap,   bw, bh }, mouse)) {
                        window.close();
                    }
                }
            }

            // ── SETUP ─────────────────────────────────────────────────────
            else if (screen == Screen::SETUP) {
                if (event.type == sf::Event::MouseButtonPressed &&
                    event.mouseButton.button == sf::Mouse::Left)
                {
                    float cx = WIN_W / 2.f;
                    // Total players +/-
                    if (UI::contains({ cx - 160, 180, 40, 36 }, mouse)) {
                        if (setup.totalPlayers > 2) {
                            setup.totalPlayers--;
                            if (setup.humanCount > setup.totalPlayers)
                                setup.humanCount = setup.totalPlayers;
                        }
                    }
                    if (UI::contains({ cx + 120, 180, 40, 36 }, mouse)) {
                        if (setup.totalPlayers < 6) setup.totalPlayers++;
                    }

                    // Human players +/-
                    if (UI::contains({ cx - 160, 250, 40, 36 }, mouse)) {
                        if (setup.humanCount > 0) setup.humanCount--;
                    }
                    if (UI::contains({ cx + 120, 250, 40, 36 }, mouse)) {
                        if (setup.humanCount < setup.totalPlayers) setup.humanCount++;
                    }

                    // Name fields
                    int total = setup.totalPlayers;
                    for (int i = 0; i < total; ++i) {
                        float fy = 320.f + i * 48.f;
                        if (UI::contains({ cx - 160, fy, 320, 36 }, mouse)) {
                            setup.editingIdx = i;
                            while ((int)setup.names.size() <= i) setup.names.push_back("");
                            setup.inputBuffer = setup.names[i];
                        }
                    }

                    // Start button
                    if (UI::contains({ cx - 120, 320.f + total * 48.f + 20.f, 240, 46 }, mouse)) {
                        // Build player list
                        std::vector<std::pair<std::string, bool>> specs;
                        for (int i = 0; i < total; ++i) {
                            bool isBot = (i >= setup.humanCount);
                            std::string name;
                            if (i < (int)setup.names.size() && !setup.names[i].empty())
                                name = setup.names[i];
                            else
                                name = isBot ? ("Bot " + std::to_string(i + 1))
                                : ("Player " + std::to_string(i + 1));
                            specs.push_back({ name, isBot });
                        }
                        gs.startGame(specs);
                        showColorPicker = false;
                        hoverCard = -1;
                        botClock.restart();
                        screen = Screen::GAME;
                    }

                    // Back
                    if (UI::contains({ 20, 20, 80, 36 }, mouse)) {
                        screen = Screen::MAIN_MENU;
                    }
                }

                // Text entry for names
                if (event.type == sf::Event::TextEntered && setup.editingIdx >= 0) {
                    while ((int)setup.names.size() <= setup.editingIdx)
                        setup.names.push_back("");

                    if (event.text.unicode == '\b') {
                        if (!setup.inputBuffer.empty())
                            setup.inputBuffer.pop_back();
                    }
                    else if (event.text.unicode == '\r' || event.text.unicode == '\n') {
                        setup.names[setup.editingIdx] = setup.inputBuffer;
                        setup.editingIdx = -1;
                    }
                    else if (event.text.unicode < 128 && setup.inputBuffer.size() < 14) {
                        setup.inputBuffer += (char)event.text.unicode;
                    }
                    if (setup.editingIdx >= 0)
                        setup.names[setup.editingIdx] = setup.inputBuffer;
                }

                if (event.type == sf::Event::KeyPressed &&
                    event.key.code == sf::Keyboard::Tab &&
                    setup.editingIdx >= 0)
                {
                    setup.names[setup.editingIdx] = setup.inputBuffer;
                    setup.editingIdx = (setup.editingIdx + 1) % setup.totalPlayers;
                    while ((int)setup.names.size() <= setup.editingIdx)
                        setup.names.push_back("");
                    setup.inputBuffer = setup.names[setup.editingIdx];
                }
            }

            // ── GAME ──────────────────────────────────────────────────────
            else if (screen == Screen::GAME) {
                if (gs.phase == GamePhase::GAME_OVER) {
                    screen = Screen::GAME_OVER;
                    break;
                }

                if (event.type == sf::Event::MouseButtonPressed &&
                    event.mouseButton.button == sf::Mouse::Left)
                {
                    // ── Color picker ──────────────────────────────────────
                    if (showColorPicker) {
                        float ox = WIN_W / 2.f - 180;
                        float oy = WIN_H / 2.f - 60;
                        sf::Color cols[4] = {
                            sf::Color(220,50,50), sf::Color(50,180,80),
                            sf::Color(50,100,220), sf::Color(240,200,40)
                        };
                        CardColor gameCols[4] = {
                            CardColor::RED, CardColor::GREEN,
                            CardColor::BLUE, CardColor::YELLOW
                        };
                        for (int i = 0; i < 4; ++i) {
                            if (UI::contains({ ox + i * 90.f, oy, 80, 80 }, mouse)) {
                                gs.setWildColor(gameCols[i]);
                                showColorPicker = false;
                                // Advance turn was called inside setWildColor
                                botClock.restart();
                            }
                        }
                        break; // don't process other clicks while picker is open
                    }

                    // Only allow human player to click
                    Player& cur = gs.currentPlayer();
                    if (cur.isBot) break;

                    // ── Click on player's hand card ───────────────────────
                    int    cardCount = cur.handSize();
                    float  cardW = CardRenderer::CARD_W;
                    float  cardH = CardRenderer::CARD_H;
                    float  spacing = std::min(90.f, (WIN_W - 60.f) / (cardCount + 1));
                    float  startX = (WIN_W - spacing * (cardCount - 1) - cardW) / 2.f;
                    float  cardY = WIN_H - cardH - 50.f;

                    for (int i = 0; i < cardCount; ++i) {
                        float cx = startX + i * spacing;
                        if (UI::contains({ cx, cardY - 20, cardW, cardH + 20 }, mouse)) {
                            if (gs.canPlay(cur.hand[i])) {
                                bool ok = gs.humanPlayCard(i);
                                if (ok) {
                                    if (gs.phase == GamePhase::COLOR_PICK)
                                        showColorPicker = true;
                                    else
                                        botClock.restart();
                                }
                            }
                            else {
                                gs.statusMsg = "Can't play that card!";
                            }
                            break;
                        }
                    }

                    // ── Click on deck (draw) ──────────────────────────────
                    float deckX = WIN_W / 2.f - CardRenderer::CARD_W - 20;
                    float deckY = WIN_H / 2.f - CardRenderer::CARD_H / 2.f;
                    if (UI::contains({ deckX, deckY,
                                      (float)CardRenderer::CARD_W,
                                      (float)CardRenderer::CARD_H }, mouse))
                    {
                        if (!cur.isBot) {
                            gs.humanDraw();
                            botClock.restart();
                        }
                    }
                }

                // ESC => back to menu
                if (event.type == sf::Event::KeyPressed &&
                    event.key.code == sf::Keyboard::Escape)
                {
                    screen = Screen::MAIN_MENU;
                }
            }

            // ── GAME OVER ─────────────────────────────────────────────────
            else if (screen == Screen::GAME_OVER) {
                if (event.type == sf::Event::MouseButtonPressed) {
                    float bx = WIN_W / 2.f - 120;
                    float by = WIN_H / 2.f + 80;
                    if (UI::contains({ bx, by, 240, 50 }, mouse))
                        screen = Screen::MAIN_MENU;
                }
            }
        }

        // ── Bot turn logic (timer-based) ───────────────────────────────────
        if (screen == Screen::GAME &&
            gs.phase == GamePhase::PLAYING &&
            !showColorPicker &&
            gs.currentPlayer().isBot)
        {
            if (botClock.getElapsedTime().asSeconds() >= BOT_DELAY) {
                gs.runBotTurn();
                botClock.restart();
                if (gs.phase == GamePhase::GAME_OVER)
                    screen = Screen::GAME_OVER;
            }
        }

        // ── Hover tracking (card highlight) ───────────────────────────────
        hoverCard = -1;
        menuHover = -1;
        if (screen == Screen::GAME && gs.phase == GamePhase::PLAYING &&
            !showColorPicker && !gs.currentPlayer().isBot)
        {
            Player& cur = gs.currentPlayer();
            int  cardCount = cur.handSize();
            float cardW = CardRenderer::CARD_W;
            float cardH = CardRenderer::CARD_H;
            float spacing = std::min(90.f, (WIN_W - 60.f) / (cardCount + 1));
            float startX = (WIN_W - spacing * (cardCount - 1) - cardW) / 2.f;
            float cardY = WIN_H - cardH - 50.f;

            for (int i = 0; i < cardCount; ++i) {
                float cx = startX + i * spacing;
                if (UI::contains({ cx, cardY - 20, cardW, cardH + 20 }, mouse))
                    hoverCard = i;
            }
        }
        if (screen == Screen::MAIN_MENU) {
            float bx = WIN_W / 2.f - 120, by0 = 300, bw = 240, bh = 50, gap = 70;
            if (UI::contains({ bx,by0,    bw,bh }, mouse)) menuHover = 0;
            if (UI::contains({ bx,by0 + gap,bw,bh }, mouse)) menuHover = 1;
        }

        // ── Draw ──────────────────────────────────────────────────────────
        window.clear();
        drawBG(window);

        if (screen == Screen::MAIN_MENU) drawMainMenu(window, font, menuHover);
        else if (screen == Screen::SETUP)     drawSetupScreen(window, font, setup);
        else if (screen == Screen::GAME) {
            drawGame(window, font, gs, hoverCard, showColorPicker);
            if (showColorPicker) drawColorPicker(window, font);
        }
        else if (screen == Screen::GAME_OVER) drawGameOver(window, font, gs);

        window.display();
    }
    return 0;
}

// ═════════════════════════════════════════════════════════════════════════
//  MAIN MENU
// ═════════════════════════════════════════════════════════════════════════
void drawMainMenu(sf::RenderWindow& w, const sf::Font& font, int hover) {
    // Title
    UI::drawCentredText(w, font, "UNO", WIN_W / 2.f, 130, 96,
        sf::Color(240, 60, 60), true);
    UI::drawCentredText(w, font, "Card Game Simulator", WIN_W / 2.f, 220, 26,
        sf::Color(240, 240, 240));

    float bx = WIN_W / 2.f - 120, by0 = 300, bw = 240, bh = 50, gap = 70;

    sf::Color c0 = (hover == 0) ? sf::Color(100, 100, 200) : sf::Color(60, 60, 140);
    sf::Color c1 = (hover == 1) ? sf::Color(160, 60, 60) : sf::Color(120, 30, 30);

    UI::drawButton(w, font, "Play", bx, by0, bw, bh, c0);
    UI::drawButton(w, font, "Quit", bx, by0 + gap, bw, bh, c1);

    UI::drawCentredText(w, font, "DSA Project  |  BSCS Sem 3",
        WIN_W / 2.f, WIN_H - 24, 14, sf::Color(160, 200, 160));
}

// ═════════════════════════════════════════════════════════════════════════
//  SETUP SCREEN
// ═════════════════════════════════════════════════════════════════════════
void drawSetupScreen(sf::RenderWindow& w, const sf::Font& font, SetupData& setup) {
    float cx = WIN_W / 2.f;

    UI::drawCentredText(w, font, "Game Setup", cx, 90, 36,
        sf::Color(255, 220, 80), true);

    // Total players row
    UI::drawCentredText(w, font, "Total Players:", cx - 70, 197, 18,
        sf::Color(220, 220, 220));
    UI::drawButton(w, font, "-", cx - 160, 180, 40, 36, sf::Color(80, 30, 30));
    UI::drawCentredText(w, font, std::to_string(setup.totalPlayers),
        cx, 197, 22, sf::Color(255, 255, 100));
    UI::drawButton(w, font, "+", cx + 120, 180, 40, 36, sf::Color(30, 80, 30));

    // Human players row
    UI::drawCentredText(w, font, "Human Players:", cx - 70, 267, 18,
        sf::Color(220, 220, 220));
    UI::drawButton(w, font, "-", cx - 160, 250, 40, 36, sf::Color(80, 30, 30));
    UI::drawCentredText(w, font, std::to_string(setup.humanCount),
        cx, 267, 22, sf::Color(180, 255, 180));
    UI::drawButton(w, font, "+", cx + 120, 250, 40, 36, sf::Color(30, 80, 30));

    int bots = setup.totalPlayers - setup.humanCount;
    std::string modeStr = std::to_string(setup.humanCount) + " human" +
        (setup.humanCount != 1 ? "s" : "") + " vs " +
        std::to_string(bots) + " bot" + (bots != 1 ? "s" : "");
    UI::drawCentredText(w, font, modeStr, cx, 298, 15, sf::Color(160, 200, 255));

    // Name fields
    int total = setup.totalPlayers;
    for (int i = 0; i < total; ++i) {
        bool isBot = (i >= setup.humanCount);
        float fy = 320.f + i * 48.f;

        std::string label = isBot ? ("Bot " + std::to_string(i + 1)) :
            ("Player " + std::to_string(i + 1));
        sf::Color fieldColor = (setup.editingIdx == i) ?
            sf::Color(60, 80, 120) : sf::Color(40, 55, 85);

        // Field box
        sf::RectangleShape field(sf::Vector2f(320, 36));
        field.setPosition(cx - 160, fy);
        field.setFillColor(fieldColor);
        field.setOutlineColor(sf::Color(120, 160, 220));
        field.setOutlineThickness(1.5f);
        w.draw(field);

        std::string displayName;
        if (i < (int)setup.names.size() && !setup.names[i].empty())
            displayName = setup.names[i];
        else
            displayName = label;

        if (setup.editingIdx == i) displayName += "|";

        sf::Text nameText;
        nameText.setFont(font);
        nameText.setString(displayName);
        nameText.setCharacterSize(16);
        nameText.setFillColor(isBot ? sf::Color(180, 220, 255) : sf::Color(255, 255, 200));
        nameText.setPosition(cx - 150, fy + 8);
        w.draw(nameText);
    }

    // Start button
    float startY = 320.f + total * 48.f + 20.f;
    UI::drawButton(w, font, "Start Game!", cx - 120, startY, 240, 46,
        sf::Color(60, 140, 60));

    // Back
    UI::drawButton(w, font, "Back", 20, 20, 80, 36, sf::Color(80, 40, 40), sf::Color::White, 15);

    UI::drawCentredText(w, font, "Click a name field and type to rename  |  Tab to switch",
        cx, WIN_H - 22, 13, sf::Color(150, 180, 150));
}

// ═════════════════════════════════════════════════════════════════════════
//  GAME SCREEN
// ═════════════════════════════════════════════════════════════════════════
void drawGame(sf::RenderWindow& w, const sf::Font& font, GameState& gs,
    int hoverCard, bool showColorPicker)
{
    const float cw = CardRenderer::CARD_W;
    const float ch = CardRenderer::CARD_H;

    // ── Discard pile (center-right) ───────────────────────────────────────
    float discardX = WIN_W / 2.f + 20;
    float discardY = WIN_H / 2.f - ch / 2.f;
    CardRenderer::drawCard(w, gs.topDiscard(), discardX, discardY, font);

    // Current colour indicator
    sf::Color ci;
    switch (gs.currentColor) {
    case CardColor::RED:    ci = sf::Color(220, 50, 50);   break;
    case CardColor::GREEN:  ci = sf::Color(50, 180, 80);   break;
    case CardColor::BLUE:   ci = sf::Color(50, 100, 220);  break;
    case CardColor::YELLOW: ci = sf::Color(240, 200, 40);  break;
    default:                ci = sf::Color(160, 160, 160); break;
    }
    sf::CircleShape colorDot(12);
    colorDot.setFillColor(ci);
    colorDot.setOutlineColor(sf::Color::White);
    colorDot.setOutlineThickness(2.f);
    colorDot.setPosition(discardX + cw + 10, discardY + ch / 2.f - 12);
    w.draw(colorDot);

    // ── Draw pile (center-left) ───────────────────────────────────────────
    float deckX = WIN_W / 2.f - cw - 20;
    float deckY = WIN_H / 2.f - ch / 2.f;
    CardRenderer::drawCardBack(w, deckX, deckY);

    // Deck size
    UI::drawCentredText(w, font,
        std::to_string(gs.deck.size()),
        deckX + cw / 2.f, deckY - 18, 14,
        sf::Color(200, 255, 200));
    UI::drawCentredText(w, font, "DRAW",
        deckX + cw / 2.f, deckY + ch + 8, 13,
        sf::Color(200, 200, 200));

    // Draw-stack warning
    if (gs.drawStack > 0) {
        std::ostringstream oss;
        oss << "Draw stack: +" << gs.drawStack;
        UI::drawCentredText(w, font, oss.str(),
            WIN_W / 2.f, WIN_H / 2.f - ch / 2.f - 28, 18,
            sf::Color(255, 80, 80), true);
    }

    // ── Opponent hands (top / sides) ─────────────────────────────────────
    int n = (int)gs.players.size();
    Player& curP = gs.currentPlayer();

    // Determine layout positions for opponents (everyone except humanIdx==0 when human)
    // We just skip current viewer's hand (always last drawn at bottom)
    // Opponents arranged in an arc at top

    int humanViewIdx = 0; // for simplicity, Player 0 is the viewer (if human)
    // In multi-human games, show current player's hand at bottom
    int viewerIdx = gs.currentPlayerIdx;

    // If current player is bot, show the "waiting" player's hand at bottom
    // For simplicity: always show player 0's hand at bottom if human,
    // or show current player at bottom
    int bottomIdx = 0;
    for (int i = 0; i < n; ++i)
        if (!gs.players[i].isBot) { bottomIdx = i; break; }

    // Draw opponents' card backs in arc at top
    {
        int opCount = n - 1;
        float topY = 30.f;
        float sectionW = WIN_W / (float)(opCount + 1);

        int drawn = 0;
        for (int i = 0; i < n; ++i) {
            if (i == bottomIdx) continue;
            float cx2 = sectionW * (drawn + 1);
            Player& op = gs.players[i];

            // Small card-back pile
            int shown = std::min(op.handSize(), 7);
            float backW = 36, backH = 54;
            float startOX = cx2 - (shown * 18.f) / 2.f;
            for (int k = 0; k < shown; ++k)
                CardRenderer::drawCardBack(w, startOX + k * 18.f, topY, 0.45f);

            // Name + card count
            bool isActive = (i == gs.currentPlayerIdx);
            sf::Color nameCol = isActive ? sf::Color(255, 230, 80) : sf::Color(200, 220, 255);
            std::string tag = op.name + " (" + std::to_string(op.handSize()) + ")";
            if (op.saidUno && op.handSize() == 1) tag += " UNO!";
            UI::drawCentredText(w, font, tag, cx2, topY + backH + 12, 14, nameCol,
                isActive);

            // Active arrow
            if (isActive) {
                sf::ConvexShape arrow;
                arrow.setPointCount(3);
                arrow.setPoint(0, { -10,0 }); arrow.setPoint(1, { 10,0 }); arrow.setPoint(2, { 0,14 });
                arrow.setFillColor(sf::Color(255, 230, 80));
                arrow.setPosition(cx2, topY + backH + 30);
                w.draw(arrow);
            }
            drawn++;
        }
    }

    // ── Current player's hand (bottom) ────────────────────────────────────
    {
        Player& p = gs.players[bottomIdx];
        int cardCount = p.handSize();
        if (cardCount == 0) {
            UI::drawCentredText(w, font, p.name + " has no cards!", WIN_W / 2.f,
                WIN_H - 90, 22, sf::Color(255, 200, 80));
        }
        else {
            float maxW = WIN_W - 60.f;
            float spacing = std::min(90.f, maxW / (float)cardCount);
            float startX = (WIN_W - spacing * (cardCount - 1) - cw) / 2.f;
            float cardY = WIN_H - ch - 50.f;

            bool isCurrentPlayer = (bottomIdx == gs.currentPlayerIdx);

            for (int i = 0; i < cardCount; ++i) {
                float cx2 = startX + i * spacing;
                bool  hl = (i == hoverCard) && isCurrentPlayer;
                bool  playable = isCurrentPlayer && gs.canPlay(p.hand[i]);
                float yOff = hl ? -18.f : (playable ? -8.f : 0.f);
                CardRenderer::drawCard(w, p.hand[i], cx2, cardY + yOff, font, hl);

                if (!playable && isCurrentPlayer && !p.isBot) {
                    // Dim unplayable cards
                    sf::RectangleShape dim(sf::Vector2f(cw, ch));
                    dim.setPosition(cx2, cardY + yOff);
                    dim.setFillColor(sf::Color(0, 0, 0, 90));
                    w.draw(dim);
                }
            }

            // Player label
            bool isActive = (bottomIdx == gs.currentPlayerIdx);
            sf::Color nc = isActive ? sf::Color(255, 230, 80) : sf::Color(200, 220, 255);
            std::string tag = p.name + " (" + std::to_string(cardCount) + " cards)";
            if (p.saidUno && cardCount == 1) tag += "  🎉 UNO!";
            UI::drawCentredText(w, font, tag, WIN_W / 2.f, WIN_H - 22, 15, nc, isActive);
        }
    }

    // ── Direction indicator ────────────────────────────────────────────────
    {
        std::string dir = gs.direction == 1 ? "► Clockwise" : "◄ Counter-CW";
        UI::drawCentredText(w, font, dir, WIN_W - 100, WIN_H / 2.f, 13,
            sf::Color(180, 220, 180));
    }

    // ── Status bar ────────────────────────────────────────────────────────
    if (!showColorPicker)
        UI::drawStatusBar(w, font, gs.statusMsg, WIN_W, WIN_H);

    // ── ESC hint ──────────────────────────────────────────────────────────
    sf::Text hint;
    hint.setFont(font);
    hint.setString("ESC = Menu");
    hint.setCharacterSize(12);
    hint.setFillColor(sf::Color(160, 200, 160));
    hint.setPosition(8, WIN_H - 55);
    w.draw(hint);
}

// ═════════════════════════════════════════════════════════════════════════
//  COLOR PICKER OVERLAY
// ═════════════════════════════════════════════════════════════════════════
void drawColorPicker(sf::RenderWindow& w, const sf::Font& font) {
    UI::drawOverlay(w, sf::Color(0, 0, 0, 170));

    UI::drawCentredText(w, font, "Choose a Color", WIN_W / 2.f, WIN_H / 2.f - 90,
        26, sf::Color::White, true);

    float ox = WIN_W / 2.f - 180;
    float oy = WIN_H / 2.f - 60;

    sf::Color cols[4] = {
        sf::Color(220,50,50), sf::Color(50,180,80),
        sf::Color(50,100,220), sf::Color(240,200,40)
    };
    std::string labels[4] = { "Red","Green","Blue","Yellow" };

    for (int i = 0; i < 4; ++i) {
        sf::RectangleShape box(sf::Vector2f(80, 80));
        box.setPosition(ox + i * 90, oy);
        box.setFillColor(cols[i]);
        box.setOutlineColor(sf::Color::White);
        box.setOutlineThickness(2.f);
        w.draw(box);

        UI::drawCentredText(w, font, labels[i],
            ox + i * 90 + 40, oy + 92, 15,
            sf::Color::White);
    }
}

